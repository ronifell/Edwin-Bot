{
  "name": "edwin-whatsapp-bot-backend",
  "version": "1.0.0",
  "description": "Node.js backend for WhatsApp legal intake bot with Z-API + OpenAI",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:admin": "npm run dev --prefix Admin",
    "test:scenarios": "node scripts/simulateScenarios.js",
    "test:conversation-md": "node scripts/simulateConversationMd.js",
    "test:conversation-md-full": "node scripts/simulateAllConversationMd.js",
    "build:blocklist": "node scripts/buildBlocklist.js",
    "db:init": "node scripts/initDb.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.71.1",
    "pg": "^8.20.0"
  }
}
