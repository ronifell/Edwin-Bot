PORT=3000
NODE_ENV=development
BOT_CHANNEL_MODE=local
LOCAL_TEST_UI_ENABLED=true

ZAPI_INSTANCE_ID=your_instance_id
ZAPI_TOKEN=your_zapi_token
ZAPI_BASE_URL=https://api.z-api.io
CLIENT_TOKEN=your_client_token
# Set false only if you intentionally want Z-API to auto-mark inbound messages as read on the linked session.
ZAPI_DISABLE_AUTO_READ_ON_START=true

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_ENABLE_REPLY_GENERATION=false

ADMIN_REPORT_NUMBER=573001112233
DEFAULT_COUNTRY_PREFIX=57
ALLOWED_INBOUND_NUMBERS=

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/edwin_bot
POSTGRES_SSL=false
ADMIN_API_TOKEN=change_me_admin_token
ADMIN_PASSWORD=

MIN_TYPING_DELAY_MS=1300
MAX_TYPING_DELAY_MS=3800
HUMAN_TYPING_CHARS_PER_SECOND=7
HUMAN_MIN_THINKING_MS=900
HUMAN_MAX_THINKING_MS=2400
HUMAN_PAUSE_PER_PUNCTUATION_MS=120
RESPONSE_DELAY_MULTIPLIER=5
TYPING_EFFECT_ENABLED=true
PRESERVE_UNREAD_ENABLED=true
